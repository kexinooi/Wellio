<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Assignment_2_v2" parent="Theme.Material3.Light.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/purple_start</item>
        <item name="android:windowBackground">@color/bg_dashboard</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:statusBarColor">@color/bg_dashboard</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Assignment_2_v2" parent="Base.Theme.Assignment_2_v2" />

    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Custom Chip style for mood selection -->
    <style name="Widget.App.Chip.Choice" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/chip_background_selector</item>
        <item name="android:textColor">@color/chip_text_color_selector</item>
        <item name="chipStrokeColor">@color/chip_background_selector</item>
        <item name="checkedIconTint">@color/white</item>
    </style>
</resources>