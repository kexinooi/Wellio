<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll_recommendations"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F0EB"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/layout_recommendations_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Toolbar area -->
        <RelativeLayout
            android:id="@+id/layout_recommendations_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_chevron"
                app:tint="@color/text_black"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tv_recommendations_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="Recommendations"
                android:textColor="@color/text_black"
                android:textSize="20sp"
                android:textStyle="bold" />

        </RelativeLayout>

        <TextView
            android:id="@+id/tv_personalized_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Personalized for You"
            android:textColor="@color/text_black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Sleep Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rec_sleep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#DAD1F6"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            tools:strokeColor="#BDB7E1">

            <RelativeLayout
                android:id="@+id/layout_rec_sleep_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/iv_rec_sleep_icon"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/ic_moon_star" />

                <LinearLayout
                    android:id="@+id/layout_rec_sleep_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="40dp"
                    android:layout_toEndOf="@id/iv_rec_sleep_icon"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_rec_sleep_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sleep"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_rec_sleep_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Improve Sleep Quality"
                        android:textColor="@color/text_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_rec_sleep_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Your average sleep is 6.2h. Aim for 7–8 hours for better well-being."
                        android:textColor="@color/text_grey_dark"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_set_sleep_reminder"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/rec_sleep_accent"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:text="Set Sleep Reminder"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="10dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_rec_sleep_chevron"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_black" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Movement Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rec_movement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#C7EBD0"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:strokeColor="#B9DABE"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:id="@+id/layout_rec_movement_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/iv_rec_movement_icon"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/ic_runner" />

                <LinearLayout
                    android:id="@+id/layout_rec_movement_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="40dp"
                    android:layout_toEndOf="@id/iv_rec_movement_icon"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_rec_movement_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Movement"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_rec_movement_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Try to Move More"
                        android:textColor="@color/text_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_rec_movement_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="A short walk can boost your mood!"
                        android:textColor="@color/text_grey_dark"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_explore_workouts"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/rec_movement_accent"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:text="Explore Workouts"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="10dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_rec_movement_chevron"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_black" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Mind Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rec_mind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#FBEAD3"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:strokeColor="#EACEB0"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:id="@+id/layout_rec_mind_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/iv_rec_mind_icon"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/ic_brain" />

                <LinearLayout
                    android:id="@+id/layout_rec_mind_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="40dp"
                    android:layout_toEndOf="@id/iv_rec_mind_icon"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_rec_mind_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mind"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_rec_mind_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Manage Stress"
                        android:textColor="@color/text_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_rec_mind_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Take 5 minutes to breathe and reset."
                        android:textColor="@color/text_grey_dark"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_try_breathing"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/rec_mind_accent"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:text="Try Breathing Exercises"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="10dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_rec_mind_chevron"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_black" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Habit Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_rec_habit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#EBF5FF"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:strokeColor="#B3CAE3"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:id="@+id/layout_rec_habit_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/iv_rec_habit_icon"
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:src="@drawable/ic_open_book" />

                <LinearLayout
                    android:id="@+id/layout_rec_habit_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="40dp"
                    android:layout_toEndOf="@id/iv_rec_habit_icon"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_rec_habit_category"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Habit"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_rec_habit_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Build a Reflection Habit"
                        android:textColor="@color/text_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_rec_habit_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Keep learning to track your progress daily."
                        android:textColor="@color/text_grey_dark"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_start_habit"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="@color/rec_habit_accent"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:text="Start Habit"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="10dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_rec_habit_chevron"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/text_black" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>