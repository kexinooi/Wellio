<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_mood_selector_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:elevation="4dp"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingVertical="0dp">

    <!-- Very Bad -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_very_bad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#E2D4FB"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/layout_very_bad_content"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/iv_mood_very_bad"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/mood_very_bad" />

            <TextView
                android:id="@+id/tv_label_very_bad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Very Bad"
                android:textColor="#4B2E83"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bad -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_bad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#FBD6C7"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/layout_bad_content"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/iv_mood_bad"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/mood_bad" />

            <TextView
                android:id="@+id/tv_label_bad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Bad"
                android:textColor="#8A3D00"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Okay -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_okay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#F8DDB4"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/layout_okay_content"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/iv_mood_okay"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/mood_okay" />

            <TextView
                android:id="@+id/tv_label_okay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Okay"
                android:textColor="#7A5A00"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Good -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_good"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#CEFDCF"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/layout_good_content"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/iv_mood_good"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/mood_good" />

            <TextView
                android:id="@+id/tv_label_good"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Good"
                android:textColor="#1F6B2A"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Amazing -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_amazing"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="4dp"
        android:layout_weight="1"
        app:cardBackgroundColor="#CDF8EF"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/layout_amazing_content"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/iv_mood_amazing"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/mood_amazing" />

            <TextView
                android:id="@+id/tv_label_amazing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Amazing"
                android:textColor="#005F5A"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>