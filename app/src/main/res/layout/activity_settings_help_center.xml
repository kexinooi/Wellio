<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/help_page_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="18dp">

            <ImageView
                android:id="@+id/btn_back_help"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Back"
                android:padding="4dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/help_title" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Help Center"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textColor="@color/help_title"
                android:layout_marginStart="14dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Frequently Asked Questions"
            android:textSize="14sp"
            android:textColor="@color/help_subtitle"
            android:layout_marginBottom="14dp" />

        <!-- FAQ 1 -->
        <LinearLayout
            android:id="@+id/faq_log_mood"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_help_card"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tv_question_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How do I log my mood?"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/help_question_text" />

                <ImageView
                    android:id="@+id/iv_arrow_1"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="@color/help_arrow_tint"
                    android:contentDescription="Expand" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tv_answer_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Go to the mood page, choose your mood, add notes if needed, then save your entry."
                android:textSize="13sp"
                android:textColor="@color/help_answer_text"
                android:layout_marginTop="12dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- FAQ 2 -->
        <LinearLayout
            android:id="@+id/faq_edit_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_help_card"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How do I edit my profile?"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/help_question_text" />

                <ImageView
                    android:id="@+id/iv_arrow_2"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="@color/help_arrow_tint"
                    android:contentDescription="Expand" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tv_answer_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Open Settings, tap Edit Profile, update your details, then press Save Changes."
                android:textSize="13sp"
                android:textColor="@color/help_answer_text"
                android:layout_marginTop="12dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- FAQ 3 -->
        <LinearLayout
            android:id="@+id/faq_reminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_help_card"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How do I set mood reminders?"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/help_question_text" />

                <ImageView
                    android:id="@+id/iv_arrow_3"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="@color/help_arrow_tint"
                    android:contentDescription="Expand" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tv_answer_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Go to Settings, turn on Mood Reminders, then tap the reminder section to choose your preferred time."
                android:textSize="13sp"
                android:textColor="@color/help_answer_text"
                android:layout_marginTop="12dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- FAQ 4 -->
        <LinearLayout
            android:id="@+id/faq_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_help_card"
            android:padding="18dp"
            android:layout_marginBottom="12dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How do I change my password?"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/help_question_text" />

                <ImageView
                    android:id="@+id/iv_arrow_4"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="@color/help_arrow_tint"
                    android:contentDescription="Expand" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tv_answer_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Go to Settings, open Account &amp; Security, tap Change Password, then enter your current and new password."
                android:textSize="13sp"
                android:textColor="@color/help_answer_text"
                android:layout_marginTop="12dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- FAQ 5 -->
        <LinearLayout
            android:id="@+id/faq_contact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_help_card"
            android:padding="18dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Need more help?"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/help_question_text" />

                <ImageView
                    android:id="@+id/iv_arrow_5"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:src="@drawable/ic_arrow_forward"
                    app:tint="@color/help_arrow_tint"
                    android:contentDescription="Expand" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tv_answer_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You can contact support at support@wellio.com."
                android:textSize="13sp"
                android:textColor="@color/help_answer_text"
                android:layout_marginTop="12dp"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>