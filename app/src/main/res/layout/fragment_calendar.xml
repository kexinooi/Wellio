                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_day_30"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30"
                    android:textColor="@color/text_black"
                    android:textStyle="bold" />

                <View
                    android:id="@+id/view48"
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/circle_blue_bg" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_columnWeight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_day_31"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="31"
                    android:textColor="@color/text_black"
                    android:textStyle="bold" />

            </LinearLayout>

        </GridLayout>

        <!-- Daily Logs Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_daily_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#E8EAF6"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E3E2F5"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tv_selected_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="May 30, 2024"
                    android:textColor="@color/text_black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Log 1: Good -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="50dp"
                            android:layout_height="54dp">

                            <View
                                android:id="@+id/view_sphere_shadow_1"
                                android:layout_width="26dp"
                                android:layout_height="4dp"
                                android:layout_gravity="bottom|center_horizontal"
                                android:layout_marginBottom="4dp"
                                android:background="@drawable/sphere_shadow" />

                            <ImageView
                                android:id="@+id/iv_mood_1"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_gravity="top"
                                android:src="@drawable/mood_good" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_log_1_mood"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Good"
                                android:textColor="@color/text_black"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_log_1_tags"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Motivated, Focused"
                                android:textColor="@color/text_grey_dark"
                                android:textSize="12sp"
                                android:textStyle="bold|italic" />

                            <TextView
                                android:id="@+id/tv_log_1_note"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Had a productive study session."
                                android:textColor="@color/text_grey_dark"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/btn_play_1"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="@color/text_grey_light" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Log 2: Okay -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <FrameLayout
                            android:layout_width="50dp"
                            android:layout_height="54dp">

                            <View
                                android:id="@+id/view_sphere_shadow_2"
                                android:layout_width="26dp"
                                android:layout_height="4dp"
                                android:layout_gravity="bottom|center_horizontal"
                                android:layout_marginBottom="4dp"
                                android:background="@drawable/sphere_shadow" />

                            <ImageView
                                android:id="@+id/iv_mood_2"
                                android:layout_width="match_parent"
                                android:layout_height="42dp"
                                android:layout_gravity="top"
                                android:src="@drawable/mood_okay" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_log_2_mood"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Okay"
                                android:textColor="@color/text_black"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_log_2_tags"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tired"
                                android:textColor="@color/text_grey_dark"
                                android:textSize="12sp"
                                android:textStyle="bold|italic" />

                            <TextView
                                android:id="@+id/tv_log_2_note"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Slept late, but getting back on track."
                                android:textColor="@color/text_grey_dark"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/btn_play_2"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_media_play"
                            app:tint="@color/text_grey_light" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Legend -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/view_legend_very_bad"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/circle_blue_bg" />

                    <TextView
                        android:id="@+id/tv_legend_very_bad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Very Bad"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/view_legend_bad"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/dot_green"
                        app:tint="#81C784" />

                    <TextView
                        android:id="@+id/tv_legend_bad"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Bad"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/view_legend_okay"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/dot_orange" />

                    <TextView
                        android:id="@+id/tv_legend_okay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Okay"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/view_legend_good"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/dot_green"
                        app:tint="#FF9800" />

                    <TextView
                        android:id="@+id/tv_legend_good"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Good"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <View
                        android:id="@+id/view_legend_amazing"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/dot_teal"
                        app:tint="#F44336" />

                    <TextView
                        android:id="@+id/tv_legend_amazing"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Amazing"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Log Mood Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_log_mood_bottom"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="100dp"
            android:text="Log Mood"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/purple_start"
            app:elevation="4dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>