<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll_profile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dashboard"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/layout_profile_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Toolbar area -->
        <RelativeLayout
            android:id="@+id/layout_profile_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_profile_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="Profile"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_black" />

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_settings"
                app:tint="@color/text_black" />
        </RelativeLayout>

        <!-- Avatar -->
        <FrameLayout
            android:id="@+id/layout_avatar_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp">
            <ImageView
                android:id="@+id/img_profile_avatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@android:drawable/sym_def_app_icon"
                android:scaleType="centerCrop"
                android:background="@drawable/circle_blue_bg"
                android:backgroundTint="#B2EBF2"
                android:clipToOutline="true"
                android:contentDescription="Profile Avatar" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kexin"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_black" />

        <TextView
            android:id="@+id/tv_achievements_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Achievements"
            android:textColor="@color/text_black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Achievement 1 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_achievement_streak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/achievement_streak_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/achievement_streak_stroke"
            app:strokeWidth="2dp">

            <LinearLayout
                android:id="@+id/layout_achievement_streak_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_streak_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_blue_bg"
                    android:backgroundTint="@color/achievement_streak_icon_bg"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="@color/achievement_streak_icon_tint" />

                <LinearLayout
                    android:id="@+id/layout_streak_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_achievement_streak_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7-Day Streak"
                        android:textColor="@color/text_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_achievement_streak_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Logged mood for 7 days"
                        android:textColor="@color/text_grey_dark"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Achievement 2 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_achievement_mindful"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="40dp"
            app:cardBackgroundColor="@color/achievement_mindful_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/achievement_mindful_stroke"
            app:strokeWidth="2dp">

            <LinearLayout
                android:id="@+id/layout_achievement_mindful_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <FrameLayout
                    android:id="@+id/layout_mindful_star_container"
                    android:layout_width="40dp"
                    android:layout_height="40dp">

                    <ImageView
                        android:id="@+id/iv_mindful_star"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="@color/achievement_mindful_icon_tint" />

                    <TextView
                        android:id="@+id/tv_mindful_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="3"
                        android:textColor="@color/achievement_mindful_count_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/layout_mindful_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_achievement_mindful_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mindful Reflections"
                        android:textColor="@color/achievement_mindful_title"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_achievement_mindful_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Added 5 notes"
                        android:textColor="@color/achievement_mindful_desc"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>