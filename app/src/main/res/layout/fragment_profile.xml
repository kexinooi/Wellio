<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll_profile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dashboard"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/layout_profile_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Toolbar area -->
        <RelativeLayout
            android:id="@+id/layout_profile_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_back_chevron"
                app:tint="@color/text_black" />

            <TextView
                android:id="@+id/tv_profile_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="Profile"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_black" />

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:src="@drawable/ic_settings"
                app:tint="@color/text_black" />
        </RelativeLayout>

        <!-- Avatar -->
        <FrameLayout
            android:id="@+id/layout_avatar_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp">
            <View
                android:id="@+id/view_avatar_bg"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/circle_blue_bg"
                android:backgroundTint="#B2EBF2" />
        </FrameLayout>

        <TextView
            android:id="@+id/tv_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kexin"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_black" />

        <TextView
            android:id="@+id/tv_streak_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7-Day Logging Streak 🔥"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_black" />

        <TextView
            android:id="@+id/tv_streak_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Keep it up!"
            android:textColor="@color/text_grey_dark"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Your Stats Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_stats"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:strokeColor="#E1E1DA"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/layout_stats_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_stats_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Stats"
                    android:textColor="@color/text_black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/layout_stats_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <!-- Avg Mood -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_avg_mood"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#EAF8EC"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#91AA9D"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:id="@+id/layout_avg_mood_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="17dp">

                            <ImageView
                                android:id="@+id/iv_avg_mood_icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginTop="3dp"
                                android:layout_marginBottom="4dp"
                                android:src="@drawable/mood_good" />

                            <TextView
                                android:id="@+id/tv_avg_mood_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Avg Mood"
                                android:textColor="@color/text_grey_dark"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tv_avg_mood_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Good"
                                android:textColor="@color/text_black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_avg_mood_period"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="This Month"
                                android:textColor="@color/text_grey_light"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Avg Sleep -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_avg_sleep"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_marginHorizontal="4dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#D7E6F7"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#A4B8CB"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:id="@+id/layout_avg_sleep_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="17dp">

                            <ImageView
                                android:id="@+id/iv_avg_sleep_icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginTop="3dp"
                                android:layout_marginBottom="4dp"
                                android:src="@android:drawable/ic_lock_idle_alarm"
                                app:tint="#3F51B5" />

                            <TextView
                                android:id="@+id/tv_avg_sleep_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Avg Sleep"
                                android:textColor="@color/text_grey_dark"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_avg_sleep_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="6.4 h"
                                android:textColor="@color/text_black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_avg_sleep_period"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="This Week"
                                android:textColor="@color/text_grey_light"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Productivity -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_productivity"
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#E3DCF6"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#B5B0DA"
                        app:strokeWidth="2dp">

                        <LinearLayout
                            android:id="@+id/layout_productivity_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="17dp">

                            <ImageView
                                android:id="@+id/iv_productivity_icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginTop="3dp"
                                android:layout_marginBottom="4dp"
                                android:src="@android:drawable/ic_notification_overlay"
                                app:tint="#D32F2F" />

                            <TextView
                                android:id="@+id/tv_productivity_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Productivity"
                                android:textColor="@color/text_grey_dark"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_productivity_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="75%"
                                android:textColor="@color/text_black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_productivity_period"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="This Week"
                                android:textColor="@color/text_grey_light"
                                android:textSize="10sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_achievements_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Achievements"
            android:textColor="@color/text_black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Achievement 1 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_achievement_streak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#BFE9C8"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="#ACD1B4"
            app:strokeWidth="2dp">

            <LinearLayout
                android:id="@+id/layout_achievement_streak_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_streak_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_blue_bg"
                    android:backgroundTint="#80CBC4"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_today"
                    app:tint="#00695C" />

                <LinearLayout
                    android:id="@+id/layout_streak_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_achievement_streak_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7-Day Streak"
                        android:textColor="@color/text_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_achievement_streak_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Logged mood for 7 days"
                        android:textColor="@color/text_grey_dark"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_streak_check"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/checkbox_on_background"
                    app:tint="#00695C" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Achievement 2 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_achievement_mindful"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="40dp"
            app:cardBackgroundColor="#DCD1F6"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="#C5BEE2"
            app:strokeWidth="2dp">

            <LinearLayout
                android:id="@+id/layout_achievement_mindful_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <FrameLayout
                    android:id="@+id/layout_mindful_star_container"
                    android:layout_width="40dp"
                    android:layout_height="40dp">

                    <ImageView
                        android:id="@+id/iv_mindful_star"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@android:drawable/btn_star_big_on"
                        app:tint="#7B1FA2" />

                    <TextView
                        android:id="@+id/tv_mindful_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="3"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <LinearLayout
                    android:id="@+id/layout_mindful_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_achievement_mindful_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mindful Reflections"
                        android:textColor="@color/text_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_achievement_mindful_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Added 5 notes"
                        android:textColor="@color/text_grey_dark"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_mindful_check"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@android:drawable/checkbox_on_background"
                    app:tint="#7B1FA2" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>