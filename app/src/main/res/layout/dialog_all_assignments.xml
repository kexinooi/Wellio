<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_dialog_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingBottom="32dp">

    <View
        android:id="@+id/view_bottom_sheet_handle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="#D1D1D1" />

    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:text="All Assignments"
        android:textColor="@color/text_black"
        android:textSize="20sp"
        android:textStyle="bold" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_dialog_assignments"
        android:layout_width="match_parent"
        android:layout_height="400dp">

        <LinearLayout
            android:id="@+id/layout_dialog_assignments_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <!-- Assignment 1 -->
            <RelativeLayout
                android:id="@+id/layout_dialog_assignment_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/dialog_icon_container_1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="@color/deadline_icon_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/iv_dialog_assignment_icon_1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_deadline_clipboard"
                        app:tint="#4CAF50" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/layout_dialog_assignment_text_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/dialog_icon_container_1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_dialog_assignment_name_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MAD Assignment"
                        android:textColor="@color/text_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_dialog_assignment_due_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Due May 12, 2024"
                        android:textColor="@color/text_grey_light"
                        android:textSize="14sp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_dialog_deadline_status_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:cardBackgroundColor="@color/deadline_red_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:id="@+id/layout_dialog_status_badge_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp">

                        <View
                            android:id="@+id/view_dialog_status_dot_1"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/circle_red" />

                        <TextView
                            android:id="@+id/tv_dialog_deadline_days_left_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2 days left"
                            android:textColor="@color/deadline_red_text"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

            <View
                android:id="@+id/view_dialog_divider_1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F5F5F5" />

            <!-- Assignment 2 -->
            <RelativeLayout
                android:id="@+id/layout_dialog_assignment_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/dialog_icon_container_2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="@color/deadline_icon_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/iv_dialog_assignment_icon_2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_deadline_clipboard"
                        app:tint="#4CAF50" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/layout_dialog_assignment_text_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/dialog_icon_container_2"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_dialog_assignment_name_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ME Assignment"
                        android:textColor="@color/text_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_dialog_assignment_due_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Due May 18, 2024"
                        android:textColor="@color/text_grey_light"
                        android:textSize="14sp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_dialog_deadline_status_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:cardBackgroundColor="@color/deadline_orange_bg"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:id="@+id/layout_dialog_status_badge_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp">

                        <View
                            android:id="@+id/view_dialog_status_dot_2"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/circle_orange" />

                        <TextView
                            android:id="@+id/tv_dialog_deadline_days_left_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8 days left"
                            android:textColor="@color/deadline_orange_text"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

            <View
                android:id="@+id/view_dialog_divider_2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F5F5F5" />

            <!-- Networking Quiz -->
            <RelativeLayout
                android:id="@+id/layout_dialog_assignment_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/dialog_icon_container_3"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardBackgroundColor="@color/deadline_icon_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:id="@+id/iv_dialog_assignment_icon_3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_deadline_clipboard"
                        app:tint="#4CAF50" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/layout_dialog_assignment_text_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/dialog_icon_container_3"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_dialog_assignment_name_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Networking Quiz"
                        android:textColor="@color/text_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_dialog_assignment_due_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Due May 22, 2024"
                        android:textColor="@color/text_grey_light"
                        android:textSize="14sp" />
                </LinearLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_dialog_deadline_status_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:cardBackgroundColor="#E8F5E9"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:id="@+id/layout_dialog_status_badge_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="6dp">

                        <View
                            android:id="@+id/view_dialog_status_dot_3"
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/dot_green" />

                        <TextView
                            android:id="@+id/tv_dialog_deadline_days_left_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12 days left"
                            android:textColor="#2E7D32"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>