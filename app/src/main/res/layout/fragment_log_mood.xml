<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dashboard"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/layout_log_mood_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Toolbar -->
        <RelativeLayout
            android:id="@+id/layout_log_mood_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_back_chevron"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/text_black" />

            <TextView
                android:id="@+id/tv_log_mood_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="Log Mood"
                android:textColor="@color/text_black"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tv_feeling_question"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="How are you feeling today?"
            android:textColor="@color/text_black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_select_mood_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Select your mood"
            android:textColor="@color/text_grey_light"
            android:textSize="14sp"
            android:textStyle="bold" />

        <include
            android:id="@+id/layout_mood_selector"
            layout="@layout/item_mood_selector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/tv_influence_question"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="What influenced your mood?"
            android:textColor="@color/text_black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_select_influence_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Select all that apply"
            android:textColor="@color/text_grey_light"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_influences"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:chipSpacingHorizontal="12dp"
            app:chipSpacingVertical="10dp"
            app:singleLine="false"
            app:singleSelection="false"
            app:selectionRequired="false">

            <!-- Exhausted -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_exhausted"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Exhausted"
                android:checkable="true"
                android:textColor="@color/chip_text_color_selector"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:checkedIcon="@drawable/ic_check_rounded"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/log_mood_chip_selected_text"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="@color/log_mood_stroke"
                app:chipStrokeWidth="1dp" />

            <!-- Happy -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_happy"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Happy"
                android:checkable="true"
                android:textColor="@color/chip_text_color_selector"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:checkedIcon="@drawable/ic_check_rounded"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/log_mood_chip_selected_text"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="@color/log_mood_stroke"
                app:chipStrokeWidth="1dp" />

            <!-- Motivated -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_motivated"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motivated"
                android:checkable="true"
                android:textColor="@color/chip_text_color_selector"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:checkedIcon="@drawable/ic_check_rounded"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/log_mood_chip_selected_text"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="@color/log_mood_stroke"
                app:chipStrokeWidth="1dp" />

            <!-- Focused -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_focused"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Focused"
                android:checkable="true"
                android:textColor="@color/chip_text_color_selector"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:checkedIcon="@drawable/ic_check_rounded"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/log_mood_chip_selected_text"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="@color/log_mood_stroke"
                app:chipStrokeWidth="1dp" />

            <!-- Stressed -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_stressed"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stressed"
                android:checkable="true"
                android:textColor="@color/chip_text_color_selector"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:checkedIcon="@drawable/ic_check_rounded"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/log_mood_chip_selected_text"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="@color/log_mood_stroke"
                app:chipStrokeWidth="1dp" />

            <!-- Anxious -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_anxious"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anxious"
                android:checkable="true"
                android:textColor="@color/chip_text_color_selector"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:checkedIcon="@drawable/ic_check_rounded"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/log_mood_chip_selected_text"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="@color/log_mood_stroke"
                app:chipStrokeWidth="1dp" />

            <!-- Tired -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_tired"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tired"
                android:checkable="true"
                android:textColor="@color/chip_text_color_selector"
                app:chipBackgroundColor="@color/chip_background_selector"
                app:checkedIcon="@drawable/ic_check_rounded"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/log_mood_chip_selected_text"
                app:chipCornerRadius="20dp"
                app:chipStrokeColor="@color/log_mood_stroke"
                app:chipStrokeWidth="1dp" />

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:id="@+id/tv_add_note_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Add a note (optional)"
            android:textColor="@color/text_black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_note_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/log_mood_note_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="@color/log_mood_note_stroke"
            app:strokeWidth="1dp">

            <RelativeLayout
                android:id="@+id/layout_note_relative"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <EditText
                    android:id="@+id/et_note"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:layout_toStartOf="@id/iv_mic"
                    android:background="@null"
                    android:gravity="top"
                    android:hint="What's on your mind?"
                    android:textColor="@color/text_black"
                    android:textColorHint="@color/text_grey_light"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/iv_mic"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="4dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="@color/primary_blue" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_mood"
            android:layout_width="250dp"
            android:layout_height="52dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/btn_gradient_purple"
            android:text="Save Mood"
            android:textAllCaps="false"
            android:textColor="@color/calendar_button_text"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>