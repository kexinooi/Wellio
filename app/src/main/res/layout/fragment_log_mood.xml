<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dashboard"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Toolbar area -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:clickable="true"
                android:focusable="true"
                android:src="@drawable/ic_back_chevron"
                app:tint="@color/text_black" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="Log Mood"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_black" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How are you feeling today?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:textColor="@color/text_black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Select your mood"
            android:textColor="@color/text_grey_light"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Mood Selection Row -->
        <include
            layout="@layout/item_mood_selector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="What influenced your mood?"
            android:textColor="@color/text_black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Select all that apply"
            android:textColor="@color/text_grey_light"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Influence Chips -->

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:chipSpacingHorizontal="15dp"
            app:chipSpacingVertical="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip3"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:elevation="4dp"
                android:text="Exhausted"
                android:textColor="@color/text_grey_dark"
                app:chipBackgroundColor="#F0F0F0"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:elevation="4dp"
                android:text="Happy"
                app:chipBackgroundColor="#F0F0F0"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:elevation="4dp"
                android:text="Motivated"
                android:textColor="@color/text_grey_dark"
                app:chipBackgroundColor="#EEEEEE"
                app:chipIconVisible="true"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:elevation="4dp"
                android:text="Focused"
                android:textColor="@color/text_grey_dark"
                app:chipBackgroundColor="#EEEEEE"
                app:chipIconVisible="true"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip2"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:elevation="4dp"
                android:text="Stressed"
                android:textColor="@color/text_grey_dark"
                app:chipBackgroundColor="#F0F0F0"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:elevation="4dp"
                android:text="Anxious"
                app:chipBackgroundColor="#F0F0F0"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:elevation="4dp"
                android:text="Tired"
                android:textColor="@color/text_grey_dark"
                app:chipBackgroundColor="#F0F0F0"
                app:chipStrokeWidth="0dp" />

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="9dp"
            android:text="Add a note (optional)"
            android:textColor="@color/text_black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <EditText
                    android:id="@+id/et_note"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:layout_toStartOf="@id/iv_mic"
                    android:background="@null"
                    android:gravity="top"
                    android:hint="What's on your mind?"
                    android:textColorHint="@color/text_grey_light"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/iv_mic"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="4dp"
                    android:elevation="4dp"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="@color/primary_blue" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save Mood Button -->

        <!-- Reflection Card -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_mood"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/btn_gradient_purple"
            android:text="Save Mood"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:cornerRadius="50dp"
            app:elevation="8dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>