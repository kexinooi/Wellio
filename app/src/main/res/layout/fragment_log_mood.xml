<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dashboard"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Toolbar area -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/text_black" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="Log Mood"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/text_black" />
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="@color/text_black" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How are you feeling today?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:textColor="@color/text_black" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select your mood"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_grey_light" />

        <!-- Mood Selection Row -->
        <include
            layout="@layout/item_mood_selector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What influenced your mood?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:textColor="@color/text_black" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select all that apply"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_grey_light" />

        <!-- Influence Chips -->
        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stressed"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:textColor="@color/text_grey_dark"
                app:chipBackgroundColor="#F0F0F0"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motivated"
                android:checked="true"
                app:chipIcon="@android:drawable/checkbox_on_background"
                app:chipIconVisible="true"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                app:chipBackgroundColor="#A5D6A7"
                android:textColor="#2E7D32"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tired"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:textColor="@color/text_grey_dark"
                app:chipBackgroundColor="#F0F0F0"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Focused"
                android:checked="true"
                app:chipIcon="@android:drawable/checkbox_on_background"
                app:chipIconVisible="true"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                app:chipBackgroundColor="#A5D6A7"
                android:textColor="#2E7D32"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anxious"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                app:chipBackgroundColor="#F0F0F0"
                app:chipStrokeWidth="0dp" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Happy"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                app:chipBackgroundColor="#F0F0F0"
                app:chipStrokeWidth="0dp" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add a note (optional)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:textColor="@color/text_black" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E0E0E0"
            app:cardBackgroundColor="@color/white">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">
                <EditText
                    android:id="@+id/et_note"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:hint="What's on your mind?"
                    android:gravity="top"
                    android:background="@null"
                    android:textSize="14sp"
                    android:textColorHint="@color/text_grey_light"
                    android:layout_toStartOf="@id/iv_mic"
                    android:layout_marginEnd="8dp" />
                <ImageView
                    android:id="@+id/iv_mic"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_btn_speak_now"
                    app:tint="@color/primary_blue" />
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Save Mood Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_mood"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="Save Mood"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="30dp"
            android:background="@drawable/btn_gradient_purple"
            app:backgroundTint="@null"
            app:elevation="4dp" />

        <!-- Reflection Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="40dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#E8EAF6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#81C784" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nice job reflecting! 💙"
                        android:textStyle="bold"
                        android:textColor="@color/text_black"
                        android:textSize="14sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Every check-in helps you grow."
                        android:textColor="@color/text_grey_dark"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>