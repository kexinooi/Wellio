<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dashboard"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dashboard"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingTop="24dp"
        android:paddingRight="24dp"
        android:paddingBottom="24dp">

        <!-- Tab Selector -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            android:background="@color/bg_dashboard">

        <!-- Mood Tab (SELECTED DEFAULT) -->
        <LinearLayout
            android:id="@+id/tab_mood"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_tab_mood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Mood"
                android:textColor="@color/text_black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicator_mood"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@color/primary_blue"
                android:visibility="visible" />
        </LinearLayout>

        <!-- Sleep Tab -->
        <LinearLayout
            android:id="@+id/tab_sleep"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_tab_sleep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Sleep"
                android:textColor="@color/text_grey_light"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicator_sleep"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@color/sleep_purple"
                android:visibility="invisible" />
        </LinearLayout>

        <!-- Academic Tab -->
        <LinearLayout
            android:id="@+id/tab_academic"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_tab_academic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Academic"
                android:textColor="@color/text_grey_light"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/indicator_academic"
                android:layout_width="40dp"
                android:layout_height="3dp"
                android:background="@color/mood_bad"
                android:visibility="invisible" />
        </LinearLayout>
        </LinearLayout>

        <!-- Fragment Container -->
        <FrameLayout
            android:id="@+id/insights_tab_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_dashboard" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>