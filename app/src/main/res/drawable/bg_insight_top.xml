<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base Background Gradient (Deeper Lavender) -->
    <item>
        <shape>
            <gradient
                android:startColor="#CFD6FF"
                android:endColor="#E2E6FF"
                android:angle="0" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Inner Depth (Increased to 15% opacity for more richness) -->
    <item>
        <shape>
            <gradient
                android:startColor="#00000000"
                android:endColor="#26000000"
                android:angle="90" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Highlight Overlay (Glassy reflection) -->
    <item>
        <shape>
            <gradient
                android:startColor="#4DFFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</layer-list>